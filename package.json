        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@types/prismjs": "^1.26.6",
        "mdsvex": "^0.12.7",
        "prismjs": "^1.30.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-callouts": "2.1.0",
        "rehype-slug": "^6.0.0",
        "remark-github": "^12.0.0",
        "svelte": "^5.55.1",
        "svelte-canvas": "^2.1.0",
        "svelte-check": "^4.4.6",
        "svelte-sitemap": "^3.1.0",
